<main>
    <section>
        <img src="{{product.thumbnail}}" alt="{{product.title}}">
        <div>
            <h2>{{product.title}}</h2>
            <p>{{product.description}}</p>
            <p>{{product.category}}</p>
            <div>
                <p>Precio: ${{product.price}}</p>
                <p>Stock: {{product.stock}}</p>
                <p>SKU: {{product.code}}</p>
            </div>
        </div>
    </section>
</main>